# Copy this file to infra/.env (untracked - see .gitignore) and fill in real values.
# PUBLIC REPO: this .example file must never carry a real app name, region, host, or key.
#
# Used by:
#   - Taskfile.yml (`task deploy:plan` / `task deploy`) - FLY_APP, FLY_REGION
#   - infra/compose.yml (local dev only) - BUILDEX_SERVICE_KEY, BUILDEX_PUBLIC_BASE_URL

# Required for any `task deploy:plan` / `task deploy` - the Fly app name. infra/fly.toml carries no
# app identity on purpose (public repo); without this, both tasks fail with a clear message rather
# than deploying to a placeholder.
FLY_APP=

# Optional. Only needed on an app's very first deploy (Fly remembers the region afterwards). Leave
# blank to let `fly deploy` pick.
FLY_REGION=

# Local dev only (infra/compose.yml). Must be at least 32 characters - see apps/sync/src/config.ts.
BUILDEX_SERVICE_KEY=

# Local dev only (infra/compose.yml). Defaults to http://127.0.0.1:8080 if left unset.
BUILDEX_PUBLIC_BASE_URL=
