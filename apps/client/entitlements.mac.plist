<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Hardened-runtime entitlements for the notarized macOS build (B2b). Apple's notary service REQUIRES
  the hardened runtime; Electron/V8 then needs these specific exceptions or the app crashes on launch:
    - allow-jit + allow-unsigned-executable-memory: V8's JIT allocates & runs generated machine code.
    - disable-library-validation: the app spawns the operator's own `claude` CLI (a separately-signed,
      possibly-unsigned binary) and loads Electron's helper frameworks - library validation would block
      loading code signed by a different Team ID.
    - allow-dyld-environment-variables: Electron sets DYLD_* for its helper processes.
  These are the standard, minimal set for a code-signed Electron app; no network/hardware entitlements
  are requested - the daemon binds loopback only and external content runs in a locked-down partition.
  Lives at the app root (NOT build/, which is gitignored build output) so it survives a fresh clone.
-->
<plist version="1.0">
<dict>
  <key>com.apple.security.cs.allow-jit</key>
  <true/>
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>
  <key>com.apple.security.cs.allow-dyld-environment-variables</key>
  <true/>
</dict>
</plist>
